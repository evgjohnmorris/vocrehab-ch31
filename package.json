{
  "name": "vocrehab-ch31-workspace",
  "version": "1.0.0",
  "description": "VR&E Chapter 31 advocacy workspace with authority research, case workflows, career planning, calculators, and an optional SQLite backend.",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "client:dev": "npm run dev --workspace=client",
    "server:dev": "npm run dev --workspace=server",
    "clean": "node scripts/clean-workspace.mjs",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "build": "npm run build --workspace=client",
    "lint": "npm run lint --workspace=client",
    "seed": "npm run seed --workspace=server",
    "server:smoke": "npm run smoke --workspace=server",
    "test:accessibility": "npm run test:accessibility --workspace=client",
    "check": "npm run lint && npm run build && npm run server:smoke"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
