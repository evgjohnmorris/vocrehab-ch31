        <PAGEOBJECT XPOS="154" YPOS="1107" OwnPage="1" ItemID="224332688" PTYPE="4" WIDTH="504" HEIGHT="150" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L504 0 L504 150 L0 150 L0 0 Z" copath="M0 0 L504 0 L504 150 L0 150 L0 0 Z" gXpos="154" gYpos="1107" gWidth="0" gHeight="0" ALIGN="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle ALIGN="0" LINESP="13.5" FONT="Segoe UI Regular" FONTSIZE="10"/>
                <ITEXT FONT="Segoe UI Regular" FONTSIZE="10" FCOLOR="Charcoal" CH="M28C.I.A.1.01.a. Under the provisions of 38 U.S.C. Chapter 31, the Department of Veterans Affairs (VA) administers the Veteran Readiness and Employment (VR&amp;E) program. The primary mission of VR&amp;E is to assist veterans and service members with service-connected disabilities to prepare for, obtain, and maintain suitable employment. For veterans whose disabilities are too severe to pursue immediate employment, the program provides comprehensive independent living services to enhance their ability to live as independently as possible within their families and communities."/>
                <trail ALIGN="0" LINESP="13.5"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="154" YPOS="1272" OwnPage="1" ItemID="224729952" PTYPE="4" WIDTH="504" HEIGHT="120" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L504 0 L504 120 L0 120 L0 0 Z" copath="M0 0 L504 0 L504 120 L0 120 L0 0 Z" gXpos="154" gYpos="1272" gWidth="0" gHeight="0" ALIGN="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle ALIGN="0" LINESP="13.5" FONT="Segoe UI Regular" FONTSIZE="10"/>
                <ITEXT FONT="Segoe UI Regular" FONTSIZE="10" FCOLOR="Charcoal" CH="M28C.I.A.1.01.b. Authority for this program is derived from Title 38 of the United States Code (U.S.C.) and Title 38 of the Code of Federal Regulations (CFR), specifically Part 21. While the M28C manual provides operational policy and guidelines to ensure consistent decision-making, it does not supersede statutory or regulatory mandates. All determinations must ultimately align with 38 U.S.C. Chapter 31 and 38 CFR Part 21."/>
                <trail ALIGN="0" LINESP="13.5"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="154" YPOS="1412" OwnPage="1" ItemID="225132576" PTYPE="6" WIDTH="504" HEIGHT="80" FRTYPE="0" CLIPEDIT="0" PWIDTH="1.5" PCOLOR="Background_Gray" PCOLOR2="VA_Gold" PLINEART="1" path="M0 0 L504 0 L504 80 L0 80 L0 0 Z" copath="M0 0 L504 0 L504 80 L0 80 L0 0 Z" gXpos="154" gYpos="1412" gWidth="0" gHeight="0" LAYER="0"/>
        <PAGEOBJECT XPOS="168" YPOS="1422" OwnPage="1" ItemID="219978304" PTYPE="4" WIDTH="476" HEIGHT="60" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L476 0 L476 60 L0 60 L0 0 Z" copath="M0 0 L476 0 L476 60 L0 60 L0 0 Z" gXpos="168" gYpos="1422" gWidth="0" gHeight="0" ALIGN="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle ALIGN="0" LINESP="12.825" FONT="Segoe UI Semibold" FONTSIZE="9.5"/>
                <ITEXT FONT="Segoe UI Semibold" FONTSIZE="9.5" FCOLOR="Charcoal" CH="IMPORTANT NOTE"/>
                <para ALIGN="0" LINESP="12.825"/>
                <ITEXT FONT="Segoe UI Semibold" FONTSIZE="9.5" FCOLOR="Charcoal" CH="The M28C manual serves as the primary guidance for Vocational Rehabilitation Counselors (VRCs). While it interprets laws and regulations, it does not carry the weight of law. In cases of conflict, the U.S. Code and Code of Federal Regulations take precedence."/>
                <trail ALIGN="0" LINESP="12.825"/>
            </StoryText>
        </PAGEOBJECT>
