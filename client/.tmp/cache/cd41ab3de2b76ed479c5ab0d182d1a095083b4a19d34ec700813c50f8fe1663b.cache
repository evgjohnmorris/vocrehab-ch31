<!-- documentid:38_3114  usckey:380000000311400000000000000000000 currentthrough:20260430_119-87 documentPDFPage:-1 -->
<!-- itempath:/380/PART III/CHAPTER 31/Sec. 3114 -->
<!-- itemsortkey:380AAWT -->
<!-- expcite:TITLE 38-VETERANS&apos; BENEFITS!@!PART III-READJUSTMENT AND RELATED BENEFITS!@!<usCode chapter="31" edition="prelim" title="38">CHAPTER 31</usCode>-TRAINING AND REHABILITATION FOR VETERANS WITH SERVICE-CONNECTED DISABILITIES!@!Sec. 3114 -->
<!-- field-start:head -->

<h3 class="section-head">&sect;3114. Vocational rehabilitation outside the United States</h3>
<!-- field-end:head -->
<!-- field-start:statute -->

<p class="statutory-body">Under regulations which the Secretary shall prescribe, a vocational rehabilitation program under this chapter may be provided outside the United States if the Secretary determines that such training is (1) necessary in the particular case to provide the preparation needed to render a veteran employable and enable such veteran to obtain and retain suitable employment, and (2) in the best interest of such veteran and the Federal Government.</p>
<!-- field-end:statute -->

<a name="sourcecredit"></a>
<!-- field-start:sourcecredit -->

<p class="source-credit">(Added <a href="/statviewer.htm?volume=94&page=2182" target="_blank" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" style="text-decoration: none;color: #0F0D61;">
<pLaw congress="96" isPrivate="false" number="466">Pub. L. 96&ndash;466,</pLaw> title I, &sect;101(a), Oct. 17, 1980, <statuteAtLarge page="2182" volume="94">94 Stat. 2182</statuteAtLarge>
</a>, &sect;1514; amended <a href="/statviewer.htm?volume=103&page=2092" target="_blank" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" style="text-decoration: none;color: #0F0D61;">
<pLaw congress="101" isPrivate="false" number="237">Pub. L. 101&ndash;237,</pLaw> title IV, &sect;423(b)(1)(A), Dec. 18, 1989, <statuteAtLarge page="2092" volume="103">103 Stat. 2092</statuteAtLarge>
</a>; renumbered &sect;3114, <a href="/statviewer.htm?volume=105&page=406" target="_blank" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" style="text-decoration: none;color: #0F0D61;">
<pLaw congress="102" isPrivate="false" number="83">Pub. L. 102&ndash;83,</pLaw> &sect;5(a), Aug. 6, 1991, <statuteAtLarge page="406" volume="105">105 Stat. 406</statuteAtLarge>
</a>.)</p>

<br class="Q04">
<!-- field-end:sourcecredit -->
<!-- field-start:notes -->

<a name="miscellaneous-note"></a>
<!-- field-start:miscellaneous-note -->

<h4 class="note-head">
<strong>Editorial Notes</strong>
</h4>
<!-- field-end:miscellaneous-note -->

<a name="priorprovisions-note"></a>
<!-- field-start:priorprovisions-note -->

<h4 class="note-head">Prior Provisions</h4>

<p class="note-body">Prior section 3114 was renumbered <span onclick="openDocument('5314', '38', ''); return false;" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" class="stdref">section 5314 of this title</span>.</p>
<!-- field-end:priorprovisions-note -->

<a name="amendment-note"></a>
<!-- field-start:amendment-note -->

<h4 class="note-head">Amendments</h4>

<p class="note-body">
<b>1991</b>-<pLaw congress="102" isPrivate="false" number="83">Pub. L. 102&ndash;83</pLaw> renumbered <span onclick="openDocument('1514', '38', ''); return false;" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" class="stdref">section 1514 of this title</span> as this section.</p>

<p class="note-body">
<b>1989</b>-<pLaw congress="101" isPrivate="false" number="237">Pub. L. 101&ndash;237</pLaw> substituted "Secretary" for "Administrator" wherever appearing.</p>

<br class="Q04">
<!-- field-end:amendment-note -->
<!-- field-start:miscellaneous-note -->

<h4 class="note-head">
<strong>Statutory Notes and Related Subsidiaries</strong>
</h4>
<!-- field-end:miscellaneous-note -->

<a name="effectivedate-note"></a>
<!-- field-start:effectivedate-note -->

<h4 class="note-head">Effective Date</h4>

<p class="note-body">Section effective Apr. 1, 1981, see section 802(a)(1) of <pLaw congress="96" isPrivate="false" number="466">Pub. L. 96&ndash;466,</pLaw> set out as a note under <span onclick="openDocument('3100', '38', ''); return false;" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" class="stdref">section 3100 of this title</span>.</p>
<!-- field-end:effectivedate-note -->
<!-- field-end:notes -->





