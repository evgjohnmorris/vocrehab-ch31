</a>; <a href="/statviewer.htm?volume=103&page=2080" target="_blank" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" style="text-decoration: none;color: #0F0D61;">
<pLaw congress="101" isPrivate="false" number="237">Pub. L. 101&ndash;237,</pLaw> title IV, &sect;&sect;404, 423(b)(1), Dec. 18, 1989, <statuteAtLarge page="2080" volume="103">103 Stat. 2080</statuteAtLarge>
</a>, <a href="/statviewer.htm?volume=103&page=2092" target="_blank" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" style="text-decoration: none;color: #0F0D61;">2092</a>; renumbered &sect;3120 and amended <a href="/statviewer.htm?volume=105&page=406" target="_blank" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" style="text-decoration: none;color: #0F0D61;">
