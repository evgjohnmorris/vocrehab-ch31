</tr>

<tr>

<td class="left4em">Full-time </td>
<td class="middle">366 </td>
<td class="middle">454 </td>
<td class="middle">535 </td>
<td class="right">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;39</td>

</tr>

