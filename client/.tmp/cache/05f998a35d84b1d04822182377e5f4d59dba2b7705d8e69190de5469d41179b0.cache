<td class="middle">341 </td>
<td class="middle">400 </td>
<td class="right">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;30</td>

</tr>

<tr>

<td class="left4em">Half-time </td>
<td class="middle">184 </td>
<td class="middle">228 </td>
<td class="middle">268 </td>
<td class="right">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;20</td>

</tr>

<tr>

<td class="left">Farm cooperative, apprentice, or other on-job training:</td>
<td class="middle"></td>
<td class="middle"></td>
<td class="middle"></td>
<td class="right"></td>

</tr>

<tr>

<td class="left4em">Full-time </td>
<td class="middle">320 </td>
<td class="middle">387 </td>
<td class="middle">446 </td>
<td class="right">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;29</td>

</tr>

<tr>

