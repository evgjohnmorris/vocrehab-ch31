<!-- documentid:38_3109  usckey:380000000310900000000000000000000 currentthrough:20260430_119-87 documentPDFPage:-1 -->
<!-- itempath:/380/PART III/CHAPTER 31/Sec. 3109 -->
<!-- itemsortkey:380AAWO -->
<!-- expcite:TITLE 38-VETERANS&apos; BENEFITS!@!PART III-READJUSTMENT AND RELATED BENEFITS!@!<usCode chapter="31" edition="prelim" title="38">CHAPTER 31</usCode>-TRAINING AND REHABILITATION FOR VETERANS WITH SERVICE-CONNECTED DISABILITIES!@!Sec. 3109 -->
<!-- field-start:head -->

<h3 class="section-head">&sect;3109. Entitlement to independent living services and assistance</h3>
<!-- field-end:head -->
<!-- field-start:statute -->

<p class="statutory-body">In any case in which the Secretary has determined under <span onclick="openDocument('3106', '38', ''); return false;" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" class="stdref">section 3106(e) of this title</span> that the achievement of a vocational goal by a veteran currently is not reasonably feasible, such veteran shall be entitled, in accordance with the provisions of <span onclick="openDocument('3120', '38', ''); return false;" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" class="stdref">section 3120 of this title</span>, to a program of independent living services and assistance designed to enable such veteran to achieve maximum independence in daily living.</p>
<!-- field-end:statute -->

<a name="sourcecredit"></a>
<!-- field-start:sourcecredit -->

<p class="source-credit">(Added <a href="/statviewer.htm?volume=94&page=2181" target="_blank" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" style="text-decoration: none;color: #0F0D61;">
<pLaw congress="96" isPrivate="false" number="466">Pub. L. 96&ndash;466,</pLaw> title I, &sect;101(a), Oct. 17, 1980, <statuteAtLarge page="2181" volume="94">94 Stat. 2181</statuteAtLarge>
</a>, &sect;1509; amended <a href="/statviewer.htm?volume=100&page=3279" target="_blank" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" style="text-decoration: none;color: #0F0D61;">
<pLaw congress="99" isPrivate="false" number="576">Pub. L. 99&ndash;576,</pLaw> title III, &sect;333(b)(5), Oct. 28, 1986, <statuteAtLarge page="3279" volume="100">100 Stat. 3279</statuteAtLarge>
</a>; <a href="/statviewer.htm?volume=103&page=2092" target="_blank" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" style="text-decoration: none;color: #0F0D61;">
<pLaw congress="101" isPrivate="false" number="237">Pub. L. 101&ndash;237,</pLaw> title IV, &sect;423(b)(1)(A), Dec. 18, 1989, <statuteAtLarge page="2092" volume="103">103 Stat. 2092</statuteAtLarge>
</a>; renumbered &sect;3109 and amended <a href="/statviewer.htm?volume=105&page=406" target="_blank" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" style="text-decoration: none;color: #0F0D61;">
<pLaw congress="102" isPrivate="false" number="83">Pub. L. 102&ndash;83,</pLaw> &sect;5(a), (c)(1), Aug. 6, 1991, <statuteAtLarge page="406" volume="105">105 Stat. 406</statuteAtLarge>
</a>; <a href="/statviewer.htm?volume=110&page=3325" target="_blank" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" style="text-decoration: none;color: #0F0D61;">
<pLaw congress="104" isPrivate="false" number="275">Pub. L. 104&ndash;275,</pLaw> title I, &sect;101(f)(2)(B), Oct. 9, 1996, <statuteAtLarge page="3325" volume="110">110 Stat. 3325</statuteAtLarge>
</a>.)</p>

<br class="Q04">
<!-- field-end:sourcecredit -->
<!-- field-start:notes -->

<a name="miscellaneous-note"></a>
<!-- field-start:miscellaneous-note -->

<h4 class="note-head">
<strong>Editorial Notes</strong>
</h4>
<!-- field-end:miscellaneous-note -->

<a name="priorprovisions-note"></a>
<!-- field-start:priorprovisions-note -->

<h4 class="note-head">Prior Provisions</h4>

<p class="note-body">Prior section 3109 was renumbered <span onclick="openDocument('5309', '38', ''); return false;" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" class="stdref">section 5309 of this title</span>.</p>
<!-- field-end:priorprovisions-note -->

<a name="amendment-note"></a>
<!-- field-start:amendment-note -->

<h4 class="note-head">Amendments</h4>

<p class="note-body">
<b>1996</b>-<pLaw congress="104" isPrivate="false" number="275">Pub. L. 104&ndash;275</pLaw> substituted "3106(e)" for "3106(d)".</p>

<p class="note-body">
<b>1991</b>-<pLaw congress="102" isPrivate="false" number="83">Pub. L. 102&ndash;83</pLaw> renumbered <span onclick="openDocument('1509', '38', ''); return false;" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" class="stdref">section 1509 of this title</span> as this section and substituted "3106(d)" for "1506(d)" and "3120" for "1520".</p>

<p class="note-body">
<b>1989</b>-<pLaw congress="101" isPrivate="false" number="237">Pub. L. 101&ndash;237</pLaw> substituted "Secretary" for "Administrator".</p>

<p class="note-body">
<b>1986</b>-<pLaw congress="99" isPrivate="false" number="576">Pub. L. 99&ndash;576</pLaw> inserted "currently" after first reference to "veteran".</p>

<br class="Q04">
<!-- field-end:amendment-note -->
<!-- field-start:miscellaneous-note -->

<h4 class="note-head">
<strong>Statutory Notes and Related Subsidiaries</strong>
</h4>
<!-- field-end:miscellaneous-note -->

<a name="effectivedate-note"></a>
<!-- field-start:effectivedate-note -->

<h4 class="note-head">Effective Date</h4>

<p class="note-body">Section effective Apr. 1, 1981, see section 802(a)(1) of <pLaw congress="96" isPrivate="false" number="466">Pub. L. 96&ndash;466,</pLaw> set out as a note under <span onclick="openDocument('3100', '38', ''); return false;" onmouseout="this.style.textDecoration='none';" onmouseover="this.style.textDecoration='underline';" class="stdref">section 3100 of this title</span>.</p>
<!-- field-end:effectivedate-note -->
<!-- field-end:notes -->





