<div class="contextHeader">

<span class="contextHeadline">
<!-- field-start:cite -->38 USC 3116<!-- field-end:cite -->: Promotion of employment and training opportunities</span>
<span class="lawsInEffect">Text contains those laws in effect on May 24, 2026</span>
<!-- pending-update-statement -->
